<?xml version="1.0" encoding="utf-8"?>
<!--
    Test-only manifest override.

    Android's AccountManagerService will auto-bind any service declaring an
    `android.accounts.AccountAuthenticator` or `android.content.SyncAdapter`
    intent-filter when an account of the app's type exists on the device.
    In instrumented tests the Application is swapped for HiltTestApplication,
    which does not include the entry points those services rely on, so the
    binding crashes the test process.

    Removing the two services here prevents Android from binding them during
    tests, while leaving the production manifest untouched. Tests that need
    to exercise authenticator/sync-adapter behavior must not rely on these
    manifest entries.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">
    <!-- No application overrides needed: AGP 9.x does not include app services in the
         test APK manifest, so AuthenticatorService and ArticleSyncService are absent
         from the test APK and cannot be bound by the system during tests. -->
</manifest>
